#include <iostream>
#include <iomanip>
#include <cstdlib>
#include <ctime>

using namespace std;

// Создание матрицы размером rows x cols
int** createMatrix(int rows, int cols) {
    int** matrix = new int* [rows];
    for (int i = 0; i < rows; i++) {
        matrix[i] = new int[cols];
    }
    return matrix;
}

// Заполнение матрицы случайными числами от -100 до 100
void fillMatrix(int** matrix, int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            matrix[i][j] = rand() % 201 - 100;
        }
    }
}

// Вывод матрицы на экран
void printMatrix(int** matrix, int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            cout << setw(5) << matrix[i][j];
        }
        cout << endl;
    }
}

// Поворот матрицы на 90 градусов по часовой стрелке
// Исходная матрица: rows x cols
// Результат: cols x rows
int** rotateMatrixClockwise(int** matrix, int rows, int cols) {
    int** rotated = createMatrix(cols, rows);  // размеры поменялись местами

    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            // Элемент из (i, j) переходит в (j, rows - i - 1)
            rotated[j][rows - i - 1] = matrix[i][j];
        }
    }

    return rotated;
}

// Поворот матрицы на 90 градусов против часовой стрелки
// Исходная матрица: rows x cols
// Результат: cols x rows
int** rotateMatrixCounterClockwise(int** matrix, int rows, int cols) {
    int** rotated = createMatrix(cols, rows);  // размеры поменялись местами

    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            // Элемент из (i, j) переходит в (cols - j - 1, i)
            rotated[cols - j - 1][i] = matrix[i][j];
        }
    }

    return rotated;
}

// Освобождение памяти матрицы
void deleteMatrix(int** matrix, int rows) {
    for (int i = 0; i < rows; i++) {
        delete[] matrix[i];
    }
    delete[] matrix;
}

// Ввод размеров матрицы с проверкой
void getValidSizes(int& rows, int& cols) {
    while (true) {
        cout << "Введите количество строк M (0 < M <= 20): ";
        cin >> rows;
        cout << "Введите количество столбцов N (0 < N <= 20): ";
        cin >> cols;

        if (cin.fail() || rows <= 0 || rows > 20 || cols <= 0 || cols > 20) {
            cin.clear();
            cin.ignore(10000, '\n');
            cout << "Ошибка! Введите числа в пределах 1 до 20.\n";
        }
        else {
            return;
        }
    }
}

int main() {
    setlocale(LC_ALL, "Rus");
    srand(time(0));

    int rows, cols;
    getValidSizes(rows, cols);

    // Создание и заполнение исходной матрицы
    int** matrix = createMatrix(rows, cols);
    fillMatrix(matrix, rows, cols);

    cout << "\nИсходная матрица (" << rows << "x" << cols << "):\n";
    printMatrix(matrix, rows, cols);

    // Поворот по часовой стрелке
    int** rotatedClockwise = rotateMatrixClockwise(matrix, rows, cols);
    cout << "\nМатрица после поворота на 90° по часовой стрелке (" << cols << "x" << rows << "):\n";
    printMatrix(rotatedClockwise, cols, rows);

    // Поворот против часовой стрелки
    int** rotatedCounter = rotateMatrixCounterClockwise(matrix, rows, cols);
    cout << "\nМатрица после поворота на 90° против часовой стрелки (" << cols << "x" << rows << "):\n";
    printMatrix(rotatedCounter, cols, rows);

    // Освобождение памяти
    deleteMatrix(matrix, rows);
    deleteMatrix(rotatedClockwise, cols);
    deleteMatrix(rotatedCounter, cols);

    cout << "\nПамять успешно освобождена.\n";

    return 0;
}
