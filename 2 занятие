#include <iostream>
#include <iomanip>
#include <cstdlib>
#include <ctime>

using namespace std;

int** createMatrix(int n) {
    int** matrix = new int* [n];
    for (int i = 0; i < n; i++) {
        matrix[i] = new int[n];
    }
    return matrix;
}

void fillMatrix(int** matrix, int n) {
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            matrix[i][j] = rand() % 201 - 100; // от -100 до 100
        }
    }
}

void printMatrix(int** matrix, int n) {
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << setw(5) << matrix[i][j];
        }
        cout << endl;
    }
}

// Поворот матрицы на 90 градусов по часовой стрелке
int** rotateMatrixClockwise(int** matrix, int n) {
    int** rotated = createMatrix(n);

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            // rotated[j][i] = matrix[n - i - 1][j]
            rotated[j][i] = matrix[n - i - 1][j];
        }
    }

    return rotated;
}

// Поворот матрицы на 90 градусов против часовой стрелки (дополнительно)
int** rotateMatrixCounterClockwise(int** matrix, int n) {
    int** rotated = createMatrix(n);

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            // rotated[j][i] = matrix[i][n - j - 1]
            rotated[j][i] = matrix[i][n - j - 1];
        }
    }

    return rotated;
}

void deleteMatrix(int** matrix, int n) {
    for (int i = 0; i < n; i++) {
        delete[] matrix[i];
    }
    delete[] matrix;
}

int getValidSize() {
    int n;
    while (true) {
        cout << "Введите размер квадратной матрицы N (в пределах 0 < N <= 20): ";
        cin >> n;

        if (cin.fail() || n <= 0 || n > 20) {
            cin.clear();
            cin.ignore(10000, '\n');
            cout << "Ошибка! Введите целое число в пределах 0 < N <= 20.\n";
        }
        else {
            return n;
        }
    }
}

int main() {
    setlocale(LC_ALL, "Rus");
    srand(time(0));

    int n = getValidSize();

    int** matrix = createMatrix(n);

    fillMatrix(matrix, n);

    cout << "\nИсходная матрица:\n";
    printMatrix(matrix, n);

    int** rotatedClockwise = rotateMatrixClockwise(matrix, n);
    cout << "\nМатрица после поворота на 90° по часовой стрелке:\n";
    printMatrix(rotatedClockwise, n);

    int** rotatedCounter = rotateMatrixCounterClockwise(matrix, n);
    cout << "\nМатрица после поворота на 90° против часовой стрелки:\n";
    printMatrix(rotatedCounter, n);

    deleteMatrix(matrix, n);
    deleteMatrix(rotatedClockwise, n);
    deleteMatrix(rotatedCounter, n);

    return 0;
}
