#include <iostream>
#include <cmath>
using namespace std;

class NaturalNumber {
private:
    unsigned int value;

public:
    // Конструктор
    NaturalNumber(unsigned int v = 0) : value(v) {}

    // Установить значение
    void setValue(unsigned int v) {
        value = v;
    }

    // Получить значение
    unsigned int getValue() const {
        return value;
    }

    // Функция проверки: можно ли представить число в виде суммы двух квадратов натуральных чисел
    bool canBeSumOfTwoSquares() const {
        unsigned int n = value;
        if (n < 2) return false; // минимальная сумма: 1^2 + 1^2 = 2

        unsigned int limit = sqrt(n);
        for (unsigned int a = 1; a <= limit; a++) {
            unsigned int a2 = a * a;
            if (a2 > n) break;
            unsigned int b2 = n - a2;
            unsigned int b = sqrt(b2);
            if (b * b == b2 && b >= 1) {
                return true;
            }
        }
        return false;
    }
};

int main() {
    setlocale(LC_ALL, "Rus");

    int size;
    cout << "Введите количество элементов в массиве: ";
    cin >> size;

    if (size <= 0) {
        cout << "Ошибка: размер массива должен быть положительным.\n";
        return 1;
    }

    unsigned int* arr = new unsigned int[size];

    cout << "Введите " << size << " натуральных чисел:\n";
    for (int i = 0; i < size; i++) {
        cin >> arr[i];
    }

 
    int count = 0;
    cout << "\nРезультаты проверки:\n";
    for (int i = 0; i < size; i++) {
        NaturalNumber num(arr[i]);  // создаём объект класса из числа массива
        bool can = num.canBeSumOfTwoSquares();
        cout << arr[i] << " -> " << (can ? "да" : "нет") << endl;
        if (can) count++;
    }

    cout << "\nКоличество чисел, которые можно представить в виде суммы квадратов натуральных чисел: " << count << endl;

    delete[] arr;

    return 0;
}
